  text: 
  ru: "\u0420\u0410\u0417\u0411\u0415\u0419 \u0415\u0413\u041E! \n\u0422\u0410\u041C
    \u0422\u0420\u0415\u0429\u0418\u041D\u0410!\n\u041D\u0430\u0436\u043C\u0438 \u043F\u0440\u043E\u0431\u0435\u043B
